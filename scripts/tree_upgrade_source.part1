from pathlib import Path

import nbformat as nbf

ROOT = Path(__file__).resolve().parents[1]
SEED = 4317
PACKAGES = {
    "decision_tree": ROOT / "decision_tree_classification_masterclass_conda_executed" / "decision_tree_classification_masterclass",
