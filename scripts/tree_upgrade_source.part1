COMMON_EDA_NUM = r'''
model_df = df.drop(columns=ID_COL)
num_cols = [c for c in model_df.select_dtypes(include="number").columns if c != TARGET]
cat_cols = model_df.select_dtypes(exclude="number").columns.tolist()
